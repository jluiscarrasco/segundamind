rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Helper function to check if user owns the document
    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    // --- USER DATA (all user-scoped collections) ---
    // Allow CRUD if user owns the document

    match /areas/{document=**} {
      allow read, write, delete: if isAuth();
    }

    match /projects/{document=**} {
      allow read, write, delete: if isAuth();
    }

    match /tasks/{document=**} {
      allow read, write, delete: if isAuth();
    }

    match /inbox_items/{document=**} {
      allow read, write, delete: if isAuth();
    }

    match /resources/{document=**} {
      allow read, write, delete: if isAuth();
    }

    match /wiki_pages/{document=**} {
      allow read, write, delete: if isAuth();
    }

    match /user_folders/{document=**} {
      allow read, write, delete: if isAuth();
    }

    match /user_files/{document=**} {
      allow read, write, delete: if isAuth();
    }

    match /user_file_tags/{document=**} {
      allow read, write, delete: if isAuth();
    }

    match /user_file_links/{document=**} {
      allow read, write, delete: if isAuth();
    }

    match /api_tokens/{document=**} {
      allow read, write, delete: if isAuth();
    }

    match /push_subscriptions/{document=**} {
      allow read, write, delete: if isAuth();
    }

    // --- ADMIN DATA (service role only) ---
    match /allowed_emails/{document=**} {
      // Read via Cloud Function (no direct client access)
      allow read: if false;
      allow write: if false;
    }

    match /oauth_codes/{document=**} {
      // OAuth codes managed by Cloud Functions only
      allow read: if false;
      allow write: if false;
    }

    // --- DEFAULT DENY ---
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
