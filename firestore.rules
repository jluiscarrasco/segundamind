rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    // The existing document belongs to the caller (read / delete / update-source)
    function ownsExisting() {
      return isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // The incoming document belongs to the caller (create / update-target)
    function ownsIncoming() {
      return isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    // --- USER DATA (owner-only access) ---
    // read/delete: must own the existing doc.
    // create: incoming doc must be owned by caller.
    // update: must own both the existing doc and keep ownership (no reassigning).

    match /areas/{id} {
      allow read, delete: if ownsExisting();
      allow create: if ownsIncoming();
      allow update: if ownsExisting() && ownsIncoming();
    }

    match /projects/{id} {
      allow read, delete: if ownsExisting();
      allow create: if ownsIncoming();
      allow update: if ownsExisting() && ownsIncoming();
    }

    match /tasks/{id} {
      allow read, delete: if ownsExisting();
      allow create: if ownsIncoming();
      allow update: if ownsExisting() && ownsIncoming();
    }

    match /inbox_items/{id} {
      allow read, delete: if ownsExisting();
      allow create: if ownsIncoming();
      allow update: if ownsExisting() && ownsIncoming();
    }

    match /resources/{id} {
      allow read, delete: if ownsExisting();
      allow create: if ownsIncoming();
      allow update: if ownsExisting() && ownsIncoming();
    }

    match /wiki_pages/{id} {
      allow read, delete: if ownsExisting();
      allow create: if ownsIncoming();
      allow update: if ownsExisting() && ownsIncoming();
    }

    match /user_folders/{id} {
      allow read, delete: if ownsExisting();
      allow create: if ownsIncoming();
      allow update: if ownsExisting() && ownsIncoming();
    }

    match /user_files/{id} {
      allow read, delete: if ownsExisting();
      allow create: if ownsIncoming();
      allow update: if ownsExisting() && ownsIncoming();
    }

    match /user_file_tags/{id} {
      allow read, delete: if ownsExisting();
      allow create: if ownsIncoming();
      allow update: if ownsExisting() && ownsIncoming();
    }

    match /user_file_links/{id} {
      allow read, delete: if ownsExisting();
      allow create: if ownsIncoming();
      allow update: if ownsExisting() && ownsIncoming();
    }

    match /api_tokens/{id} {
      allow read, delete: if ownsExisting();
      allow create: if ownsIncoming();
      allow update: if ownsExisting() && ownsIncoming();
    }

    match /push_subscriptions/{id} {
      allow read, delete: if ownsExisting();
      allow create: if ownsIncoming();
      allow update: if ownsExisting() && ownsIncoming();
    }

    // --- ADMIN DATA (service role / Cloud Functions only) ---
    match /allowed_emails/{document=**} {
      allow read, write: if false;
    }

    match /oauth_codes/{document=**} {
      allow read, write: if false;
    }

    // --- DEFAULT DENY ---
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
