# Firebase Configuration
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_bucket.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# LLM API Key (Groq - https://console.groq.com/keys)
# SERVER-ONLY. Never prefix with VITE_ (that would leak it to the browser bundle).
GEMINI_API_KEY=your_llm_api_key_here

# Server Configuration
VITE_APP_BASE_URL=http://localhost:8082

# Login allowlist (comma-separated). If empty, anyone with a Google account
# can sign in. Set to restrict access, e.g. "you@gmail.com,other@gmail.com".
VITE_ALLOWED_EMAILS=
